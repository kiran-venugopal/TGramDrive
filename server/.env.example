PORT=3000
# IMPORTANT: Use PRODUCTION API credentials from https://my.telegram.org
# Test API credentials (small numbers like 12345) only work with test phone numbers
TELEGRAM_API_ID=your_production_api_id
TELEGRAM_API_HASH=your_production_api_hash
MONGODB_URI=mongodb://localhost:27017/telegram_drive
JWT_SECRET=your_jwt_secret_key_here
SESSION_ENCRYPTION_KEY=your_32_character_encryption_key


# Optional: Set this if you want to use a specific log level for Telegram
TELEGRAM_LOG_LEVEL=none
